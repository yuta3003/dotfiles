{{ if eq .chezmoi.os "darwin" -}}
Host github.com.main # メインアカウント
  HostName github.com
  User git
  Port 22
  IdentityFile ~/.ssh/github_main_ed25519
  TCPKeepAlive yes
  IdentitiesOnly yes

Host github.com.sub # サブアカウント
  HostName github.com
  User git
  Port 22
  IdentityFile ~/.ssh/github_sub_ed25519
  TCPKeepAlive yes
  IdentitiesOnly yes
{{ else -}}
Host github github.com
  HostName github.com
  IdentityFile ~/.ssh/id_rsa
  User git
  IdentitiesOnly yes
  Compression yes
{{ end -}}
